---
import { whatsappUrl } from '../data/site';
const whatsappHref = whatsappUrl();
---

{whatsappHref && (
  <a
    class="whatsapp-float"
    href={whatsappHref}
    target="_blank"
    rel="noreferrer"
    aria-label="Conversar com Patricia pelo WhatsApp"
  >
    <span aria-hidden="true">WA</span>
  </a>
)}
